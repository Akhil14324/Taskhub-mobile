{
  "expo": {
    "name": "TaskHub",
    "slug": "vgrandtaskhub",
    "owner": "vgrandtaskhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#4f46e5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vgrand.taskhub",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.vgrand.taskhub",
      "adaptiveIcon": {
        "backgroundColor": "#4f46e5"
      }
    },
    "extra": {
      "eas": {
        "projectId": "6ff08814-1fa6-4d0a-8a30-57eef8ed87d8"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "enableProguardInReleaseBuilds": true
          }
        }
      ]
    ]
  }
}
